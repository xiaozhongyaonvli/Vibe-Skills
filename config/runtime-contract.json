{
  "version": 1,
  "updated_at": "2026-03-15",
  "runtime_id": "vibe-governed-runtime",
  "entry_skill": "vibe",
  "host_syntax_aliases": [
    "/vibe",
    "$vibe",
    "vibe"
  ],
  "authority": {
