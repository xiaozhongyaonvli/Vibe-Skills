{
  "version": 1,
  "updated_at": "2026-03-05",
  "vendor_root": "${VCO_EXTERNAL_ROOT}/ruc-nlpir",
  "repos": {
    "FlashRAG": {
      "upstream_repo": "https://github.com/RUC-NLPIR/FlashRAG",
      "path": "${VCO_EXTERNAL_ROOT}/ruc-nlpir/FlashRAG",
      "expected_commit": "6aca76d1325c0eed9e00fba6ec692bf8b8a52b39",
      "requirements_relpath": "requirements.txt",
      "license_relpath": "LICENSE"
    },
    "WebThinker": {
      "upstream_repo": "https://github.com/RUC-NLPIR/WebThinker",
      "path": "${VCO_EXTERNAL_ROOT}/ruc-nlpir/WebThinker",
      "expected_commit": "db387eb3261de9b5e2db7d2d7fb20af2aceb7882",
      "requirements_relpath": "requirements.txt",
      "license_relpath": "LICENSE"
    }
  },
  "python": {
    "venv_path": "${VCO_EXTERNAL_ROOT}/ruc-nlpir/.venv",
    "venv_python_win": "${VCO_EXTERNAL_ROOT}/ruc-nlpir/.venv/Scripts/python.exe",
    "venv_python_unix": "${VCO_EXTERNAL_ROOT}/ruc-nlpir/.venv/bin/python"
  },
  "llm": {
    "base_url_default": "https://your-openai-compatible-endpoint/v1",
    "model_default": "your-model-id",
    "api_key_env": "VCO_INTENT_ADVICE_API_KEY",
    "base_url_env_candidates": ["VCO_INTENT_ADVICE_BASE_URL"],
    "model_env": "VCO_INTENT_ADVICE_MODEL",
    "request_timeout_seconds": 120
  },
  "web": {
    "search_keys_env": {
      "serper": "SERPER_API_KEY",
      "bing": "BING_SUBSCRIPTION_KEY",
      "jina": "JINA_API_KEY"
    },
    "notes": [
      "VCO 内置 web.run / playwright 适用于交互式深度调研（Lite 模式）；该部分不需要外部 search key。",
      "如需在本机脚本中跑“离线/批量”调研（非 tool 环境），才需要 Serper/Bing/Jina 等外部 key。"
    ]
  },
  "engine_defaults": {
    "flashrag_evidence": "auto",
    "webthinker_deep_research": "lite"
  },
  "security": {
    "never_store_api_keys_in_repo": true,
    "do_not_pass_secrets_via_cli_args": true,
    "prefer_env_vars": true,
    "reminder": "不要把 key 写入任何 JSON/脚本/日志；请用环境变量注入。"
  }
}
