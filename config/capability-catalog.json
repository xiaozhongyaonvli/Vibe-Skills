  "default_interview_questions": [
    {
      "id": "deliverable_shape",
      "prompt": "What final deliverable shape do you want for this task (script, report, document, page, or runnable workflow)?",
      "rationale": "Lock the target artifact before capability expansion."
    },
    {
      "id": "scope_surface",
      "prompt": "What is the exact scope for this task: which repo, directory, file, or data source does it live in? If you already know the target path, list it directly.",
      "rationale": "Anchor the request to the exact repo, path, or data surface."
    },
    {
      "id": "available_context",
      "prompt": "What inputs or context do you already have available (existing code, samples, errors, screenshots, APIs, data, or reference links)?",
      "rationale": "Collect the existing materials needed to avoid fragmented follow-up questions."
    },
    {
      "id": "hard_constraints",
      "prompt": "What hard constraints or off-limits areas apply to this task (time, performance, compatibility, permissions, budget, untouched areas, or forbidden methods)?",
      "rationale": "Expose delivery constraints before execution planning."
    },
    {
      "id": "execution_posture",
      "prompt": "What do you want me to do first in this run: clarify and propose a plan, or start implementation/execution directly?",
      "rationale": "Separate clarification-first from execution-first intent."
    },
    {
      "id": "acceptance_and_verification",
      "prompt": "What result counts as done for you? Please give the acceptance criteria, key outputs, and how you want me to verify them.",
      "rationale": "Define done-state and verification up front."
    }
  ],
