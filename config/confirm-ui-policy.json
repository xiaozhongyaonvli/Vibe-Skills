{
  "version": 1,
  "updated": "2026-03-03",
  "enabled": true,
  "emit_on_route_modes": [
    "confirm_required",
    "pack_overlay"
  ],
  "options": {
    "max_skill_options": 5,
    "include_descriptions": true,
    "include_scores": true,
    "include_pack_alternatives": true,
    "max_pack_alternatives": 2
  },
  "unattended": {
    "enabled": true,
    "sticky": {
      "enabled": true,
      "ttl_minutes": 360
    },
    "prompt_triggers": {
      "enable_patterns": [
        "进入无人值守",
        "开启无人值守",
        "无人值守模式",
        "enter\\s+unattended\\s+mode",
        "enable\\s+unattended",
        "unattended\\s*(on|true|1)",
        "auto\\s*-?\\s*route",
        "skip\\s+confirmation",
        "自动路由",
        "跳过确认",
        "无需确认"
      ],
      "disable_patterns": [
        "退出无人值守",
        "关闭无人值守",
        "取消无人值守",
        "exit\\s+unattended\\s+mode",
        "disable\\s+unattended",
        "unattended\\s*(off|false|0)"
      ]
    },
    "override_route_mode": true,
    "override_target_route_mode": "pack_overlay"
  },
  "governed_runtime_bridge": {
    "interactive_mode": "interactive_governed",
    "unattended_mode": "interactive_governed",
    "replace_interactive_confirm_with_receipt_in_unattended": true,
    "require_requirement_and_plan_artifacts_before_execute": true
  }
}
