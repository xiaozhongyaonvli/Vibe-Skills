      "id": "evidence_mode",
      "values": ["static-structure", "shadow-replay", "operator-review", "rollback-drill"],
      "question": "What kind of evidence is needed before any board discussion?"
    },
    {
      "id": "decision_horizon",
      "values": ["hold", "review-ready", "rollback-ready"],
      "question": "How close is the slice to promotion discussion?"
    }
  ],
