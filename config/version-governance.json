      "require_nested_bundled_root": false
    }
  },
  "metrics": {
    "governed_mirror_coverage_target": 0,
    "runtime_only_artifact_count_target": 0,
    "upstream_manifest_coverage_target": 15,
    "productization_ratio_target": 0.8
  }
}
