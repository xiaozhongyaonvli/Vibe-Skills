{
    "version":  1,
    "updated":  "2026-02-26",
    "enabled":  true,
    "mode": "soft",
    "preserve_routing_assignment":  true,
    "routing_integration":  "prepack_capability_discovery",
    "scope":  {
                  "grade_allow":  [
                                      "M",
                                      "L",
                                      "XL"
                                  ],
                  "task_allow":  [
                                     "planning",
                                     "coding",
                                     "review",
                                     "debug",
                                     "research"
                                 ]
              },
    "trigger":  {
                    "min_trigger_score":  0.2,
                    "min_capability_hits":  1,
                    "ambiguity_keywords":  [
                                               "improve",
                                               "optimize",
                                               "handle end to end",
                                               "搞一下",
                                               "帮我搞定",
                                               "完整做完",
                                               "黑盒"
                                           ],
                    "composite_keywords":  [
                                               "and",
                                               "plus",
                                               "then",
                                               "同时",
                                               "并且",
                                               "再",
                                               "从",
                                               "到",
                                               "规划",
                                               "实现",
                                               "design",
                                               "implement",
                                               "brainstorm",
                                               "execute"
                                           ],
                    "execution_keywords":  [
                                               "deliverable",
                                               "report",
                                               "script",
                                               "api",
                                               "workflow",
                                               "方案",
                                               "落地",
                                               "执行",
                                               "复现",
                                               "验证"
                                           ]
                },
    "interview":  {
                      "max_questions":  6,
                                              "question_templates":  [
                                                 "What final deliverable shape do you want for this task (script, report, document, page, or runnable workflow)?",
                                                 "What is the exact scope for this task: which repo, directory, file, or data source does it live in? If you already know the target path, list it directly.",
                                                 "What inputs or context do you already have available (existing code, samples, errors, screenshots, APIs, data, or reference links)?",
                                                 "What hard constraints or off-limits areas apply to this task (time, performance, compatibility, permissions, budget, untouched areas, or forbidden methods)?",
                                                 "What do you want me to do first in this run: clarify and propose a plan, or start implementation/execution directly?",
                                                 "What result counts as done for you? Please give the acceptance criteria, key outputs, and how you want me to verify them."
                                              ]
                  },
    "intent_contract":  {
                            "required_fields":  [
                                                    "goal",
                                                    "deliverable",
                                                    "constraints",
                                                    "capabilities"
                                                ],
                            "min_completeness_for_filter":  0.6,
                            "min_completeness_for_confirm_required":  0.45
                        },
    "selection":  {
                      "apply_in_modes":  [
                                             "soft",
                                             "strict"
                                         ],
                      "require_non_empty_filter_result":  true,
                      "fallback_on_empty":  "use_full_pack_candidates"
                  },
    "runtime_prompt":  {
                           "include_digest":  true,
                           "max_capability_count":  8
                       },
    "fallback_behavior":  {
                              "on_missing_catalog":  "bypass_deep_discovery",
                              "on_error":  "continue_core_routing"
                          },
    "governed_runtime_bridge": {
                                  "state_machine_stage": "deep_interview",
                                  "require_intent_contract_receipt": true,
                                  "require_requirement_doc_handoff": true,
                                  "runtime_modes": [
                                      "interactive_governed"
                                  ]
                          }
}

