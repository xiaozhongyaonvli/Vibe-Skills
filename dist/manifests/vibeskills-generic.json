{
  "manifest_kind": "vibeskills-distribution-manifest",
  "manifest_version": 1,
  "package_id": "vibeskills-generic",
  "package_name": "VibeSkills Generic Host (Advisory-Only)",
  "status": "advisory-only",
  "runtime_role": "contract-consumer",
  "summary": "Generic hosts may consume canonical contracts and a repo-provided runtime-core payload in a neutral target root, but the repository still makes no host closure claim.",
  "truth_sources": [
    "docs/universalization/host-capability-matrix.md",
    "docs/universalization/install-matrix.md",
    "adapters/generic/host-profile.json",
    "adapters/generic/closure.json",
    "config/runtime-core-packaging.json"
  ],
  "host_adapter_ref": "adapters/generic/host-profile.json",
  "install_entrypoints": {
    "repo_provided": [
      "install.ps1 --host generic",
      "install.sh --host generic",
      "check.ps1 --host generic",
      "check.sh --host generic",
      "config/runtime-core-packaging.json"
    ],
    "host_managed": [
      "all runtime install surfaces",
      "all plugin provisioning",
      "all MCP registration",
      "all provider secret storage"
    ]
  },
  "degrade_states": {
    "current_state": "advisory-only"
  },
  "anti_overclaim": [
    "No official runtime is implied for generic hosts.",
    "No platform parity is claimed without a host-specific proof lane."
  ]
}
